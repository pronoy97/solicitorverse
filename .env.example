# Environment Variables Template
# Copy this to .env.local and fill in your values

# API Configuration
VITE_API_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# Google Analytics
VITE_GA_ID=G_XXXXXXXXXX

# Email Service (if using EmailJS)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# WhatsApp Integration
VITE_WHATSAPP_PHONE=1234567890

# Contact Information
VITE_PHONE=+1 (234) 567-8900
VITE_EMAIL=info@legalelite.com
VITE_ADDRESS=123 Legal Street, Law City, LC 12345

# Business Information
VITE_BUSINESS_NAME=LegalElite Law Firm
VITE_BUSINESS_HOURS=Monday - Friday: 9:00 AM - 6:00 PM

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_WHATSAPP=true
VITE_ENABLE_FORM_SUBMISSION=false

# Note: Variables prefixed with VITE_ are exposed to client-side code
# Never expose sensitive keys or credentials
